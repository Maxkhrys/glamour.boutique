---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Glamour Boutique Enniscorthy',
  description = 'Premium fashion boutique on Main Street, Enniscorthy. Peruzzi, Robell, Deck, Marie Mero, Masai. Honest Fashion Advice.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/logo.jpg" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#D4819A" />
    <title>{title}</title>

    <!-- Open Graph / social sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/logo.jpg" />
    <meta property="og:site_name" content="Glamour Boutique Enniscorthy" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <slot />
  </body>
</html>

<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Lenis smooth scroll — desktop only; native scroll is faster on mobile
  const isTouch = window.matchMedia('(max-width: 1024px)').matches || navigator.maxTouchPoints > 0;

  if (!isTouch) {
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    });
    gsap.ticker.add((time: number) => lenis.raf(time * 1000));
    gsap.ticker.lagSmoothing(0);
    lenis.on('scroll', ScrollTrigger.update);
    (window as any).lenis = lenis;
  }

  (window as any).gsap = gsap;
  (window as any).ScrollTrigger = ScrollTrigger;
</script>
