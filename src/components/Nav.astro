---
---

<nav class="main-nav fixed top-0 left-0 right-0 z-50 px-6 md:px-12 py-5 flex items-center justify-between" style="background-color: transparent;">
  <a href="/" aria-label="Glamour Boutique — Home" style="display:flex;align-items:center;">
    <img
      src="/images/logo.jpg"
      alt="Glamour Boutique"
      style="height:48px;width:48px;object-fit:contain;border-radius:50%;"
      fetchpriority="high"
    />
  </a>

  <!-- Desktop nav links -->
  <ul class="hidden md:flex items-center gap-10 list-none m-0 p-0">
    {['Collections', 'Brands', 'About', 'Visit'].map((link) => (
      <li>
        <a
          href={`#${link.toLowerCase()}`}
          class="nav-link text-sm tracking-wide uppercase font-dm text-charcoal"
          style="font-family: 'DM Sans', sans-serif; color: #2C2C2C; font-size: 13px; letter-spacing: 0.12em; text-decoration: none;"
        >
          {link}
        </a>
      </li>
    ))}
  </ul>

  <!-- Mobile hamburger -->
  <button
    id="mobile-menu-btn"
    class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer bg-transparent border-0"
    aria-label="Open menu"
  >
    <span class="block w-6 h-px bg-charcoal transition-all duration-300" style="background-color: #2C2C2C;"></span>
    <span class="block w-6 h-px bg-charcoal transition-all duration-300" style="background-color: #2C2C2C;"></span>
    <span class="block w-4 h-px bg-charcoal transition-all duration-300" style="background-color: #2C2C2C;"></span>
  </button>
</nav>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-cream flex flex-col items-center justify-center gap-10 md:hidden"
  style="background-color: #FAF7F4; transform: translateY(-100%); transition: transform 0.5s cubic-bezier(0.76, 0, 0.24, 1);"
>
  <img src="/images/logo.jpg" alt="Glamour Boutique" style="height:72px;width:72px;object-fit:contain;border-radius:50%;margin-bottom:8px;" />
  {['Collections', 'Brands', 'About', 'Visit'].map((link) => (
    <a
      href={`#${link.toLowerCase()}`}
      class="mobile-menu-link text-4xl font-cormorant text-charcoal"
      style="font-family: 'Cormorant Garamond', serif; color: #2C2C2C; text-decoration: none; font-weight: 300;"
    >
      {link}
    </a>
  ))}
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-menu-link');
  let open = false;

  function toggleMenu() {
    open = !open;
    if (menu) {
      menu.style.transform = open ? 'translateY(0)' : 'translateY(-100%)';
    }
  }

  btn?.addEventListener('click', toggleMenu);
  mobileLinks.forEach((link) => link.addEventListener('click', () => {
    open = true;
    toggleMenu();
  }));
</script>
