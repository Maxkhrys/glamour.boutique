---
---

<footer class="py-16 px-6 text-center" style="background-color: #FAF7F4; border-top: 1px solid rgba(158,144,133,0.15);">
  <div class="max-w-2xl mx-auto">
    <!-- Wordmark -->
    <p
      class="font-cormorant uppercase tracking-widest mb-3"
      style="font-family: 'Cormorant Garamond', serif; font-size: clamp(24px, 4vw, 36px); color: #D4819A; letter-spacing: 0.25em; font-weight: 400;"
    >
      Glamour Boutique
    </p>

    <!-- Tagline -->
    <p
      class="mb-8 text-stone"
      style="font-family: 'DM Sans', sans-serif; font-size: 13px; color: #9E9085; letter-spacing: 0.1em;"
    >
      Honest Fashion Advice &nbsp;·&nbsp; Enniscorthy &nbsp;·&nbsp; Est. 1999
    </p>

    <!-- Social icons -->
    <div class="flex items-center justify-center gap-6 mb-10">
      <!-- Instagram -->
      <a
        href="https://www.instagram.com/glamour.boutique.enniscorthy"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Follow us on Instagram"
        style="color: #D4819A; transition: opacity 0.2s;"
        onmouseenter="this.style.opacity='0.7'"
        onmouseleave="this.style.opacity='1'"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="2" width="20" height="20" rx="5" stroke="#D4819A" stroke-width="1.5"/>
          <circle cx="12" cy="12" r="4" stroke="#D4819A" stroke-width="1.5"/>
          <circle cx="17.5" cy="6.5" r="1" fill="#D4819A"/>
        </svg>
      </a>

      <!-- Facebook -->
      <a
        href="https://www.facebook.com/glamourboutiqueenniscorthy"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Find us on Facebook"
        style="color: #D4819A; transition: opacity 0.2s;"
        onmouseenter="this.style.opacity='0.7'"
        onmouseleave="this.style.opacity='1'"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 2H15C13.6739 2 12.4021 2.52678 11.4645 3.46447C10.5268 4.40215 10 5.67392 10 7V10H7V14H10V22H14V14H17L18 10H14V7C14 6.73478 14.1054 6.48043 14.2929 6.29289C14.4804 6.10536 14.7348 6 15 6H18V2Z" stroke="#D4819A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <!-- Divider -->
    <div style="width: 40px; height: 1px; background-color: #D4C5BB; margin: 0 auto 24px;"></div>

    <!-- Copyright -->
    <p style="font-family: 'DM Sans', sans-serif; font-size: 12px; color: #9E9085; letter-spacing: 0.05em;">
      &copy; 2025 Glamour Boutique Enniscorthy. All rights reserved.
    </p>
    <p style="font-family: 'DM Sans', sans-serif; font-size: 11px; color: #C0B5AC; margin-top: 8px; letter-spacing: 0.05em;">
      Designed with care &nbsp;·&nbsp; <a href="#" style="color: #D4819A; text-decoration: none;">Glamour Studio</a>
    </p>
  </div>
</footer>
