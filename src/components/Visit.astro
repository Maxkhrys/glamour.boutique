---
---

<section
  id="visit"
  class="visit-section"
  style="background-color: #2C2C2C; padding: 100px 48px;"
>
  <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;" class="visit-grid">
    <!-- Left: Info -->
    <div>
      <p
        style="font-family: 'DM Sans', sans-serif; font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase; color: #D4819A; margin-bottom: 20px;"
      >
        Find Us
      </p>
      <h2
        style="font-family: 'Cormorant Garamond', serif; font-size: clamp(36px, 4vw, 56px); font-weight: 300; color: #FFFFFF; line-height: 1.1; margin: 0 0 48px;"
      >
        Come See Us
      </h2>

      <!-- Details -->
      <div style="display: flex; flex-direction: column; gap: 28px; margin-bottom: 48px;">
        <!-- Address -->
        <div style="display: flex; gap: 16px; align-items: flex-start;">
          <div style="flex-shrink: 0; width: 20px; padding-top: 2px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="#D4819A"/>
            </svg>
          </div>
          <div>
            <p style="font-family: 'DM Sans', sans-serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: #9E9085; margin: 0 0 4px;">
              Address
            </p>
            <p style="font-family: 'DM Sans', sans-serif; font-size: 16px; color: #FFFFFF; margin: 0; line-height: 1.6;">
              26 Main Street<br />Enniscorthy, Co. Wexford
            </p>
          </div>
        </div>

        <!-- Phone -->
        <div style="display: flex; gap: 16px; align-items: flex-start;">
          <div style="flex-shrink: 0; width: 20px; padding-top: 2px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" fill="#D4819A"/>
            </svg>
          </div>
          <div>
            <p style="font-family: 'DM Sans', sans-serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: #9E9085; margin: 0 0 4px;">
              Phone
            </p>
            <a
              href="tel:0872954347"
              style="font-family: 'DM Sans', sans-serif; font-size: 16px; color: #FFFFFF; text-decoration: none;"
            >
              087 295 4347
            </a>
          </div>
        </div>

        <!-- Hours -->
        <div style="display: flex; gap: 16px; align-items: flex-start;">
          <div style="flex-shrink: 0; width: 20px; padding-top: 2px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="10" stroke="#D4819A" stroke-width="1.5"/>
              <path d="M12 6v6l4 2" stroke="#D4819A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <p style="font-family: 'DM Sans', sans-serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: #9E9085; margin: 0 0 4px;">
              Opening Hours
            </p>
            <p style="font-family: 'DM Sans', sans-serif; font-size: 16px; color: #FFFFFF; margin: 0; line-height: 1.6;">
              Monday – Saturday<br />10am – 5.30pm
            </p>
          </div>
        </div>

        <!-- Social -->
        <div style="display: flex; gap: 16px; align-items: flex-start;">
          <div style="flex-shrink: 0; width: 20px; padding-top: 2px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="2" width="20" height="20" rx="5" stroke="#D4819A" stroke-width="1.5"/>
              <circle cx="12" cy="12" r="4" stroke="#D4819A" stroke-width="1.5"/>
            </svg>
          </div>
          <div>
            <p style="font-family: 'DM Sans', sans-serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: #9E9085; margin: 0 0 4px;">
              Social
            </p>
            <p style="font-family: 'DM Sans', sans-serif; font-size: 15px; color: rgba(255,255,255,0.7); margin: 0; line-height: 1.6;">
              Also find us on Facebook and Instagram
            </p>
          </div>
        </div>
      </div>

      <!-- CTA Button -->
      <a
        href="tel:0872954347"
        style="display: inline-block; background-color: #D4819A; color: #FFFFFF; padding: 16px 40px; border-radius: 100px; font-family: 'DM Sans', sans-serif; font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; text-decoration: none; transition: transform 0.3s ease, box-shadow 0.3s ease; will-change: transform;"
        onmouseenter="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 12px 40px rgba(212,129,154,0.4)'"
        onmouseleave="this.style.transform='translateY(0)'; this.style.boxShadow='none'"
      >
        Call Us Now
      </a>
    </div>

    <!-- Right: Map -->
    <div style="position: relative; border-radius: 4px; overflow: hidden; height: 480px;">
      <div class="maps-wrapper" style="width: 100%; height: 100%;">
        <iframe
          src="https://maps.google.com/maps?q=Glamour+Boutique+Enniscorthy&output=embed"
          width="100%"
          height="100%"
          style="border: 0; display: block;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Glamour Boutique Enniscorthy on Google Maps"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .visit-grid {
      grid-template-columns: 1fr !important;
      gap: 48px !important;
    }
    .visit-section {
      padding: 60px 24px !important;
    }
  }
</style>
