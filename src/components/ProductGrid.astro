    brand: 'Masai',
    price: '€119',
    img: '/images/blue-linen-zip-top.jpg',
    badge: 'New In',
    pos: 'top center',
  },
  {
    name: 'Sage Embroidered Linen Dress',
    brand: 'Marie Mero',
    price: '€139',
    img: '/images/khaki-linen-dress.jpg',
    badge: null,
    pos: 'top center',
  },
  {
    name: 'Navy Fish Print Co-Ord',
    brand: 'Deck',
    price: '€129',
    img: '/images/fish-print-co-ord.jpg',
    badge: 'New In',
    pos: 'top center',
  },
  {
    name: 'Cream Embroidered Linen Dress',
    brand: 'Marie Mero',
