---
const products = [
  { name: 'Floral Linen Blouse', brand: 'Peruzzi', price: '€89', color: '#F2C4D0', initial: 'P' },
  { name: 'Wide Leg Trouser', brand: 'Robell', price: '€95', color: '#EAE0D8', initial: 'R' },
  { name: 'Midi Wrap Dress', brand: 'Marie Mero', price: '€129', color: '#D4C5BB', initial: 'M' },
  { name: 'Merino Cardigan', brand: 'Masai', price: '€110', color: '#C4B5A5', initial: 'M' },
  { name: 'Striped Cotton Top', brand: 'Deck', price: '€65', color: '#DDEAF5', initial: 'D' },
  { name: 'Pleated Skirt', brand: 'Peruzzi', price: '€99', color: '#F5E6EB', initial: 'P' },
  { name: 'Linen Blazer', brand: 'Marie Mero', price: '€155', color: '#EDE8E3', initial: 'M' },
  { name: 'Printed Scarf', brand: 'Glamour Exclusive', price: '€29', color: '#F0D9E0', initial: 'G' },
];
---

<section
  id="new-arrivals"
  style="background-color: #FAF7F4; padding: 100px 24px;"
>
  <div style="max-width: 1200px; margin: 0 auto;">
    <!-- Section heading -->
    <div style="margin-bottom: 64px;">
      <p
        style="font-family: 'DM Sans', sans-serif; font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase; color: #9E9085; margin-bottom: 12px;"
      >
        Just In
      </p>
      <h2
        style="font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 5vw, 64px); font-weight: 300; color: #2C2C2C; line-height: 1.05; margin: 0 0 16px;"
      >
        New This Week
      </h2>
      <p style="font-family: 'DM Sans', sans-serif; font-size: 15px; color: #9E9085; max-width: 480px; line-height: 1.7; margin: 0;">
        Fresh styles from Peruzzi, Deck &amp; more — updated every week
      </p>
    </div>

    <!-- Product Grid -->
    <div
      style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px;"
      class="product-grid"
    >
      {products.map((product) => (
        <article
          class="product-card"
          style="border-radius: 4px; overflow: hidden; background-color: #FFFFFF; cursor: pointer;"
        >
          <!-- Color placeholder top -->
          <div
            class="card-image"
            style={`background-color: ${product.color}; height: 280px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden;`}
          >
            <div class="card-image-inner" style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);">
              <span
                style={`font-family: 'Cormorant Garamond', serif; font-size: 120px; font-weight: 300; color: rgba(0,0,0,0.07); line-height: 1; user-select: none;`}
              >
                {product.initial}
              </span>
            </div>
          </div>

          <!-- Card info bottom -->
          <div style="padding: 20px 24px 24px; background-color: #FFFFFF;">
            <h3
              style="font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 400; color: #2C2C2C; margin: 0 0 6px; line-height: 1.3;"
            >
              {product.name}
            </h3>
            <p
              style="font-family: 'DM Sans', sans-serif; font-size: 12px; color: #9E9085; margin: 0 0 8px; letter-spacing: 0.05em; text-transform: uppercase;"
            >
              {product.brand}
            </p>
            <p
              style="font-family: 'DM Sans', sans-serif; font-size: 16px; font-weight: 500; color: #D4819A; margin: 0;"
            >
              {product.price}
            </p>
          </div>
        </article>
      ))}
    </div>

    <!-- Instagram link -->
    <div style="text-align: center; margin-top: 60px;">
      <p style="font-family: 'DM Sans', sans-serif; font-size: 14px; color: #9E9085; line-height: 1.7;">
        New stock arriving weekly — follow us on Instagram{' '}
        <a
          href="https://www.instagram.com/glamour.boutique.enniscorthy"
          target="_blank"
          rel="noopener noreferrer"
          style="color: #D4819A; text-decoration: underline; text-underline-offset: 3px;"
        >
          @glamour.boutique.enni
        </a>
      </p>
    </div>
  </div>
</section>

<style>
  @media (max-width: 1024px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  @media (max-width: 600px) {
    .product-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
