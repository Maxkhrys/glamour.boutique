  },
  {
    name: 'Red Linen Co-Ord Set',
    brand: 'Masai',
    price: '€225',
    img: '/images/red-linen-set.jpg',
    badge: 'New In',
    pos: 'top center',
  },
  {
    name: 'Mint Polka Dot Knit Top',
    brand: 'Robell',
    price: '€89',
    img: '/images/mint-polka-dot-top.jpg',
    badge: null,
    pos: 'top center',
  },
  {
    name: 'Pink Zebra Print Midi Dress',
    brand: 'Marie Mero',
    price: '€149',
    img: '/images/pink-zebra-dress.jpg',
    badge: 'New In',
    pos: 'top center',
  },
  {
    name: 'Blue Zebra Print Midi Dress',
    brand: 'Marie Mero',
    price: '€149',
    img: '/images/blue-zebra-dress.jpg',
    badge: null,
    pos: 'top center',
  },
  {
    name: 'Boho Patchwork Maxi Dress',
    brand: 'Peruzzi',
    price: '€169',
    img: '/images/boho-maxi-dress.jpg',
    badge: 'New In',
    pos: 'top center',
  },
  {
