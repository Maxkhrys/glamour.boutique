---
const products = [
  {
    name: 'Orchid Statement Earrings',
    brand: 'Glamour Exclusive',
    price: '€38',
    img: '/images/orchid-earrings.jpg',
    color: '#F5E8D0',
    badge: 'New In',
  },
  {
    name: 'Tropical Tie-Front Top',
    brand: 'Peruzzi',
    price: '€79',
    img: '/images/tropical-tie-top.jpg',
    color: '#F2C4D0',
    badge: 'New In',
  },
  {
    name: 'Blue Linen Zip Top',
    brand: 'Masai',
    price: '€119',
    img: '/images/blue-linen-top-full.jpg',
    color: '#DDEAF5',
    badge: 'New In',
  },
  {
    name: 'Blue Linen Zip Top — Detail',
    brand: 'Masai',
    price: '€119',
    img: '/images/blue-linen-top-detail.jpg',
    color: '#C8DCF0',
    badge: null,
  },
  {
    name: 'Amber Bead Wrap Bracelet',
    brand: 'Glamour Exclusive',
    price: '€29',
    img: '/images/amber-bracelet.jpg',
    color: '#F5E0C8',
    badge: 'New In',
  },
  {
    name: 'Wide Leg Linen Trouser',
    brand: 'Robell',
    price: '€95',
    img: null,
    color: '#EAE0D8',
    badge: null,
  },
  {
    name: 'Midi Wrap Dress',
    brand: 'Marie Mero',
    price: '€129',
    img: null,
    color: '#D4C5BB',
    badge: null,
  },
  {
    name: 'Merino Cardigan',
    brand: 'Masai',
    price: '€110',
    img: null,
    color: '#C4B5A5',
    badge: null,
  },
];
---

<section id="new-arrivals" style="background-color: #FAF7F4; padding: 100px 24px;">
  <div style="max-width: 1200px; margin: 0 auto;">

    <!-- Section heading -->
    <div style="margin-bottom: 64px;">
      <p style="font-family: 'DM Sans', sans-serif; font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase; color: #9E9085; margin-bottom: 12px;">
        Just In
      </p>
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 5vw, 64px); font-weight: 300; color: #2C2C2C; line-height: 1.05; margin: 0 0 16px;">
        New This Week
      </h2>
      <p style="font-family: 'DM Sans', sans-serif; font-size: 15px; color: #9E9085; max-width: 480px; line-height: 1.7; margin: 0;">
        Fresh styles from Peruzzi, Masai &amp; more — updated every week
      </p>
    </div>

    <!-- Product Grid -->
    <div class="product-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px;">
      {products.map((product) => (
        <article
          class="product-card"
          style="border-radius: 6px; overflow: hidden; background-color: #FFFFFF; cursor: pointer; box-shadow: 0 2px 12px rgba(44,44,44,0.06);"
        >
          <!-- Image area -->
          <div
            class="card-image"
            style={`background-color: ${product.color}; height: 320px; position: relative; overflow: hidden;`}
          >
            {product.img ? (
              <div class="card-image-inner" style="width: 100%; height: 100%; transition: transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94);">
                <img
                  src={product.img}
                  alt={product.name}
                  loading="lazy"
                  style="width: 100%; height: 100%; object-fit: cover; object-position: top center; display: block;"
                  onerror={`this.parentElement.style.display='none'; this.parentElement.parentElement.querySelector('.card-fallback').style.display='flex';`}
                />
              </div>
            ) : null}

            <!-- Fallback shown when no image or image fails -->
            <div
              class="card-fallback"
              style={`display: ${product.img ? 'none' : 'flex'}; width: 100%; height: 100%; align-items: center; justify-content: center; position: ${product.img ? 'absolute' : 'relative'}; inset: 0;`}
            >
              <span style="font-family: 'Cormorant Garamond', serif; font-size: 100px; font-weight: 300; color: rgba(0,0,0,0.07); line-height: 1; user-select: none;">
                {product.brand.charAt(0)}
              </span>
            </div>

            <!-- Badge -->
            {product.badge && (
              <span
                style="position: absolute; top: 14px; left: 14px; background-color: #D4819A; color: #FFFFFF; font-family: 'DM Sans', sans-serif; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; padding: 4px 10px; border-radius: 20px;"
              >
                {product.badge}
              </span>
            )}
          </div>

          <!-- Info -->
          <div style="padding: 20px 22px 24px; background-color: #FFFFFF;">
            <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 400; color: #2C2C2C; margin: 0 0 5px; line-height: 1.3;">
              {product.name}
            </h3>
            <p style="font-family: 'DM Sans', sans-serif; font-size: 11px; color: #9E9085; margin: 0 0 10px; letter-spacing: 0.08em; text-transform: uppercase;">
              {product.brand}
            </p>
            <div style="display: flex; align-items: center; justify-content: space-between;">
              <p style="font-family: 'DM Sans', sans-serif; font-size: 17px; font-weight: 500; color: #D4819A; margin: 0;">
                {product.price}
              </p>
              <span
                style="font-family: 'DM Sans', sans-serif; font-size: 11px; color: #9E9085; letter-spacing: 0.08em; text-transform: uppercase; border-bottom: 1px solid rgba(158,144,133,0.4); padding-bottom: 1px; cursor: pointer;"
              >
                Enquire
              </span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Instagram link -->
    <div style="text-align: center; margin-top: 60px;">
      <p style="font-family: 'DM Sans', sans-serif; font-size: 14px; color: #9E9085; line-height: 1.7;">
        New stock arriving weekly — follow us on Instagram{' '}
        <a
          href="https://www.instagram.com/glamour.boutique.enniscorthy"
          target="_blank"
          rel="noopener noreferrer"
          style="color: #D4819A; text-decoration: underline; text-underline-offset: 3px;"
        >
          @glamour.boutique.enni
        </a>
      </p>
    </div>

  </div>
</section>

<style>
  @media (max-width: 1024px) {
    .product-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 600px) {
    .product-grid { grid-template-columns: 1fr !important; }
    #new-arrivals { padding: 60px 16px !important; }
  }
  .product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 60px rgba(44,44,44,0.12) !important;
  }
  .product-card:hover .card-image-inner {
    transform: scale(1.06);
  }
</style>
