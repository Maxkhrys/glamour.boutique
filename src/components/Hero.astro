---
---

<section
  class="hero-section relative flex items-center justify-center overflow-hidden"
  style="height: 100vh; min-height: 600px;"
  id="hero"
>
  <!-- Hero photo with Ken Burns -->
  <div
    class="hero-bg absolute inset-0"
    style="transform-origin: center center; will-change: transform;"
  >
    <img
      src="https://images.unsplash.com/photo-1483985988355-763728e1935b?w=1920&h=1080&fit=crop&q=85"
      alt="Fashion boutique hero"
      style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
      fetchpriority="high"
    />
    <!-- Dark overlay for text legibility -->
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(44,44,44,0.35) 0%, rgba(44,44,44,0.55) 100%);"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
    <!-- Label -->
    <p
      class="hero-label uppercase text-sm tracking-widest mb-8"
      style="font-family: 'DM Sans', sans-serif; font-size: 11px; letter-spacing: 0.3em; color: rgba(255,255,255,0.75); opacity: 0;"
    >
      Est. 1999 &nbsp;·&nbsp; Enniscorthy, Co. Wexford
    </p>

    <!-- H1 with word splitting -->
    <h1
      class="hero-h1 font-cormorant font-light leading-tight mb-6"
      style="font-family: 'Cormorant Garamond', serif; font-size: clamp(52px, 8vw, 96px); font-weight: 300; color: #FFFFFF; line-height: 1.05; letter-spacing: -0.02em;"
    >
      Where Style Meets Warmth
    </h1>

    <!-- Subline -->
    <p
      class="hero-sub mb-10"
      style="font-family: 'DM Sans', sans-serif; font-size: clamp(15px, 2vw, 18px); color: rgba(255,255,255,0.8); opacity: 0; max-width: 520px; margin: 0 auto 2.5rem; line-height: 1.7;"
    >
      New stock arriving weekly. Brands you love, curated with care.
    </p>

    <!-- CTA Button -->
    <a
      href="#collections"
      class="hero-cta inline-block text-white rounded-full uppercase tracking-widest text-sm font-medium"
      style="background-color: #D4819A; color: #FFFFFF; padding: 16px 40px; font-family: 'DM Sans', sans-serif; font-size: 12px; letter-spacing: 0.18em; text-decoration: none; opacity: 0; transition: transform 0.3s ease, box-shadow 0.3s ease; will-change: transform;"
      onmouseenter="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 12px 40px rgba(212,129,154,0.4)'"
      onmouseleave="this.style.transform='translateY(0)'; this.style.boxShadow='none'"
    >
      Explore Collections
    </a>
  </div>

  <!-- Scroll chevron -->
  <div
    class="bounce-chevron absolute bottom-8 left-1/2"
    style="transform: translateX(-50%);"
    aria-hidden="true"
  >
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M4 7l6 6 6-6" stroke="#9E9085" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</section>
